{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(git commit:*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/check-html-sync.sh",
            "timeout": 15,
            "statusMessage": "Checking HTML nav/footer sync..."
          }
        ]
      }
    ],
    "PostToolUse": []
  }
}
